import java.util.*;

class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int count=0;
        int n = sc.nextInt();

        for(int i = 1; i <= n; i++){
            if(n % i == 0){
                System.out.println(i);
                count=count+1;
            }
        }
         System.out.println("the count of a factors:");

        System.out.println(count);
    }
}
